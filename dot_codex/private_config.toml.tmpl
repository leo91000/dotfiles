[tui]
notifications = ["agent-turn-complete", "approval-requested"]
notification_method = "osc9"

[mcp_servers.chrome-devtools]
command = "npx"
args = [
  "-y",
  "chrome-devtools-mcp@latest",
  "--executablePath=/usr/bin/google-chrome-stable",
  "--chrome-arg=--ozone-platform=wayland",
  "--chrome-arg=--enable-features=UseOzonePlatform"
]
env_vars = [
  "XDG_SESSION_TYPE",
  "WAYLAND_DISPLAY",
  "XDG_RUNTIME_DIR",
  "DBUS_SESSION_BUS_ADDRESS",
  "__GLX_VENDOR_LIBRARY_NAME",
  "LIBVA_DRIVER_NAME"
]

[mcp_servers.chrome-devtools.tools.new_page]
approval_mode = "approve"

[mcp_servers.chrome-devtools.tools.click]
approval_mode = "approve"

[mcp_servers.chrome-devtools.tools.evaluate_script]
approval_mode = "approve"

[mcp_servers.chrome-devtools.tools.navigate_page]
approval_mode = "approve"

[mcp_servers.chrome-devtools.tools.fill_form]
approval_mode = "approve"

[mcp_servers.chrome-devtools.tools.resize_page]
approval_mode = "approve"

[mcp_servers.chrome-devtools.tools.emulate]
approval_mode = "approve"

[mcp_servers.chrome-devtools.tools.take_snapshot]
approval_mode = "approve"

[mcp_servers.chrome-devtools.tools.fill]
approval_mode = "approve"

[mcp_servers.chrome-devtools.tools.press_key]
approval_mode = "approve"

[mcp_servers.chrome-devtools.tools.type_text]
approval_mode = "approve"

[mcp_servers.chrome-devtools.tools.hover]
approval_mode = "approve"

[mcp_servers.chrome-devtools.tools.upload_file]
approval_mode = "approve"

[mcp_servers.chrome-devtools.tools.get_network_request]
approval_mode = "approve"

[mcp_servers.chrome-devtools.tools.close_page]
approval_mode = "approve"

[mcp_servers.chrome-devtools.tools.take_screenshot]
approval_mode = "approve"

[mcp_servers.chrome-devtools.tools.performance_stop_trace]
approval_mode = "approve"

[mcp_servers.context7]
url = "https://mcp.context7.com/mcp"
http_headers = { "CONTEXT7_API_KEY" = "{{ onepasswordRead "op://Private/context7-codex-api-key/credential" }}" }

[mcp_servers.coolify]
command = "npx"
args = ["-y", "@masonator/coolify-mcp"]
env = { "COOLIFY_ACCESS_TOKEN" = "{{ onepasswordRead "op://Private/coolify-codex-api-key/credential" }}", "COOLIFY_BASE_URL" = "https://coolify.leo-coletta.fr" }

[mcp_servers.atlassian-rovo]
url = "https://mcp.atlassian.com/v1/mcp"

[mcp_servers.excalidraw]
url = "https://mcp.excalidraw.com/mcp"
enabled = true
required = false
startup_timeout_sec = 20
tool_timeout_sec = 60

[mcp_servers.excalidraw.tools.export_to_excalidraw]
approval_mode = "approve"

[notice]
hide_gpt5_1_migration_prompt = true
hide_rate_limit_model_nudge = true

[notice.model_migrations]
"gpt-5.1-codex-mini" = "gpt-5.2-codex"

[plugins."google-calendar@openai-curated"]
enabled = true

[plugins."gmail@openai-curated"]
enabled = true

[plugins."github@openai-curated"]
enabled = true

suppress_unstable_features_warning = true
