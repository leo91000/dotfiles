{
  "$schema": "https://opencode.ai/config.json",
  "theme": "transparent",
  "model": "openai/gpt-5-2025-08-07",
  "plugin": ["@mohak34/opencode-notifier@latest"],
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--executablePath=/usr/bin/google-chrome-stable",
        "--chrome-arg=--ozone-platform=wayland",
        "--chrome-arg=--enable-features=UseOzonePlatform"
      ],
      "environment": {
        "XDG_SESSION_TYPE": "{env:XDG_SESSION_TYPE}",
        "WAYLAND_DISPLAY": "{env:WAYLAND_DISPLAY}",
        "XDG_RUNTIME_DIR": "{env:XDG_RUNTIME_DIR}",
        "DBUS_SESSION_BUS_ADDRESS": "{env:DBUS_SESSION_BUS_ADDRESS}",
        "__GLX_VENDOR_LIBRARY_NAME": "{env:__GLX_VENDOR_LIBRARY_NAME}",
        "LIBVA_DRIVER_NAME": "{env:LIBVA_DRIVER_NAME}"
      },
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{{ onepasswordRead "op://Private/context7-codex-api-key/credential" }}"
      },
      "oauth": false,
      "enabled": true
    },
    "atlassian-rovo": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": true
    },
    "excalidraw": {
      "type": "remote",
      "url": "https://mcp.excalidraw.com/mcp",
      "timeout": 20000,
      "enabled": true
    }
  }
}
