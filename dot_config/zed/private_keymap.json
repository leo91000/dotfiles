[
  {
    "bindings": {
      "ctrl-c": ["workspace::SendKeystrokes", "escape"]
    }
  },
  {
    "context": "Editor && (edit_prediction && showing_completions)",
    "bindings": {
      "tab": "editor::AcceptEditPrediction"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-/": "terminal_panel::Toggle"
    }
  },
  {
    "context": "Dock || Terminal || Editor",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-s": "workspace::Save",
      "ctrl-shift-w": "pane::CloseActiveItem",
      "ctrl-x": "terminal_panel::ToggleFocus",
      "ctrl-shift-u": "vim::ScrollUp",
      "ctrl-shift-d": "vim::ScrollDown"
    }
  },
  {
    "context": "VimControl && !menu",
    "bindings": {
      "H": "pane::ActivatePreviousItem",
      "L": "pane::ActivateNextItem",
      "ctrl-u": ["workspace::SendKeystrokes", "ctrl-shift-u z z"],
      "ctrl-d": ["workspace::SendKeystrokes", "ctrl-shift-d z z"],
      "n": ["workspace::SendKeystrokes", "n z z z v"],
      "shift-n": ["workspace::SendKeystrokes", "shift-n z z z v"],
      "g r": "editor::FindAllReferences"
    }
  },
  {
    "context": "Editor && VimControl && !VimWaiting && !menu",
    "bindings": {
      "space space": "file_finder::Toggle",
      "space /": "workspace::NewSearch",

      "space 1": ["pane::ActivateItem", 0],
      "space 2": ["pane::ActivateItem", 1],
      "space 3": ["pane::ActivateItem", 2],
      "space 4": ["pane::ActivateItem", 3],
      "space 5": ["pane::ActivateItem", 4],
      "space 6": ["pane::ActivateItem", 5],
      "space 7": ["pane::ActivateItem", 6],
      "space 8": ["pane::ActivateItem", 7],
      "space 9": ["pane::ActivateItem", 8],
      "space 0": "pane::ActivateLastItem",

      "space a": "agent::Toggle",

      "space b b": "pane::AlternateFile",
      "space b d": "pane::CloseActiveItem",
      "space b n": "workspace::NewFile",
      "space b p": "pane::TogglePinTab",
      "space b q": "pane::CloseOtherItems",

      "space c": "pane::CloseActiveItem",

      "space d a": "debugger::Start",
      "space d b": "editor::ToggleBreakpoint",
      "space d n": "editor::GoToDiagnostic",
      "space d p": "editor::GoToPreviousDiagnostic",
      "space d t": "debugger::Stop",
      "space d u": "debug_panel::ToggleFocus",

      "space e": "project_panel::Toggle",

      "space f a": "command_palette::Toggle",
      "space f f": "file_finder::Toggle",
      "space f n": "workspace::NewFile",
      "space f p": "projects::OpenRecent",
      "space f P": "workspace::Open",
      "space f w": "text_finder::Toggle",

      "space g b": "git::Blame",
      "space g g": "git_panel::Toggle",
      "space g h D": "git::Diff",
      "space g h d": "editor::ExpandAllDiffHunks",
      "space g h R": "git::RestoreFile",
      "space g h r": "git::Restore",
      "space g p": "editor::ToggleSelectedDiffHunks",
      "space g r": "git::Restore",

      "space l a": "editor::ToggleCodeActions",
      "space l d": "editor::Hover",
      "space l f": "editor::Format",
      "space l r": "editor::Rename",

      "space m P": "markdown::OpenPreviewToTheSide",
      "space m p": "markdown::OpenPreview",

      "space n c": [
        "agent::NewExternalAgentThread",
        { "agent": "claude-acp" }
      ],
      "space n g": [
        "agent::NewExternalAgentThread",
        { "agent": "codex-acp" }
      ],

      "space O o": "outline_panel::ToggleFocus",
      "space C o": "collab_panel::ToggleFocus",

      "space p": "pane::TogglePinTab",
      "space q q": "zed::Quit",

      "space s W": "pane::DeploySearch",
      "space s b": "vim::Search",
      "space s d": "diagnostics::Deploy",
      "space s g": "workspace::NewSearch",
      "space s s": "outline::Toggle",
      "space s w": "buffer_search::Deploy",

      "space t": "terminal_panel::Toggle",
      "space u d": "workspace::ClearAllNotifications",
      "space u i": "editor::ToggleInlayHints",
      "space u w": "editor::ToggleSoftWrap",

      "space w c": "pane::CloseAllItems",
      "space w d": "pane::CloseAllItems",
      "space w s": "pane::SplitDown",
      "space w v": "pane::SplitRight",
      "space -": "pane::SplitDown",
      "space |": "pane::SplitRight",

      "cmd-k": "agent::Toggle",
      "cmd-l": "assistant::InlineAssist",
      "ctrl-\\": "agent::ToggleFocus",

      "[ b": "pane::ActivatePreviousItem",
      "] b": "pane::ActivateNextItem",
      "[ c": "editor::GoToPreviousHunk",
      "] c": "editor::GoToHunk",
      "[ d": "editor::GoToPreviousDiagnostic",
      "] d": "editor::GoToDiagnostic",
      "[ e": "editor::GoToPreviousDiagnostic",
      "] e": "editor::GoToDiagnostic",
      "[ g": "editor::GoToPreviousHunk",
      "] g": "editor::GoToHunk",
      "[ h": "editor::GoToPreviousHunk",
      "] h": "editor::GoToHunk",
      "[ q": "editor::MoveToStartOfExcerpt",
      "] q": "editor::MoveToStartOfNextExcerpt",

      "space ,": "tab_switcher::Toggle"
    }
  },
  {
    "context": "Editor && vim_mode == normal && !menu",
    "bindings": {
      "K": "editor::Hover",
      "g d": "editor::GoToDefinition",
      "g D": "editor::GoToDefinitionSplit",
      "g i": "editor::GoToImplementation",
      "g I": "editor::GoToImplementationSplit",
      "g K": "editor::ShowSignatureHelp",
      "g t": "editor::GoToTypeDefinition",
      "g T": "editor::GoToTypeDefinitionSplit",
      "g y": "editor::GoToTypeDefinition",
      "g c c": "vim::ToggleComments",
      "g r": "editor::FindAllReferences"
    }
  },
  {
    "context": "Editor && vim_mode == visual && !VimWaiting && !VimObject",
    "bindings": {
      "shift-j": "editor::MoveLineDown",
      "shift-k": "editor::MoveLineUp"
    }
  },
  {
    "context": "Editor && vim_mode == insert && !VimWaiting && !menu",
    "bindings": {
      "alt-h": "vim::Left",
      "alt-j": "vim::Down",
      "alt-k": "vim::Up",
      "alt-l": "editor::ComposeCompletion",
      "j k": "vim::NormalBefore",
      "j j": "vim::NormalBefore"
    }
  },
  {
    "context": "Editor && showing_completions",
    "bindings": {
      "alt-l": "editor::ConfirmCompletion"
    }
  },
  {
    "context": "vim_operator == d",
    "bindings": {
      "o": "editor::ExpandAllDiffHunks",
      "r": "git::Restore"
    }
  },
  {
    "context": "vim_operator == g",
    "bindings": {
      "w": "vim::HelixJumpToWord"
    }
  },
  {
    "context": "vim_mode == normal || vim_mode == visual",
    "bindings": {
      "s": "vim::HelixJumpToWord",
      "S": "vim::PushSneakBackward"
    }
  },
  {
    "context": "vim_operator == a || vim_operator == i || vim_operator == cs",
    "bindings": {
      "b": "vim::MiniBrackets",
      "q": "vim::MiniQuotes",
      "g": "vim::EntireFile"
    }
  },
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      ":": "command_palette::Toggle",
      "%": "project_panel::NewFile",
      "/": "project_panel::NewSearchInDirectory",
      "-": "project_panel::SelectParent",
      "a": "project_panel::NewFile",
      "A": "project_panel::NewDirectory",
      "c": "project_panel::Copy",
      "ctrl-6": "pane::AlternateFile",
      "d": "project_panel::Delete",
      "enter": "project_panel::OpenPermanent",
      "escape": "workspace::ToggleRightDock",
      "g g": "menu::SelectFirst",
      "h": "project_panel::CollapseSelectedEntry",
      "j": "menu::SelectNext",
      "k": "menu::SelectPrevious",
      "l": "project_panel::ExpandSelectedEntry",
      "o": "project_panel::OpenPermanent",
      "p": "project_panel::Paste",
      "q": "workspace::ToggleRightDock",
      "r": "project_panel::Rename",
      "shift-d": "project_panel::Delete",
      "shift-g": "menu::SelectLast",
      "shift-r": "project_panel::Rename",
      "space e": "project_panel::Toggle",
      "t": "project_panel::OpenPermanent",
      "v": "project_panel::OpenPermanent",
      "x": "project_panel::Cut"
    }
  },
  {
    "context": "EmptyPane || SharedScreen",
    "bindings": {
      "space space": "file_finder::Toggle",
      "space /": "workspace::NewSearch",
      "space f a": "command_palette::Toggle",
      "space f f": "file_finder::Toggle",
      "space f n": "workspace::NewFile",
      "space f p": "projects::OpenRecent",
      "space q q": "zed::Quit",
      "space s g": "workspace::NewSearch"
    }
  },
  {
    "context": "GitPanel",
    "bindings": {
      "escape": "git_panel::Close",
      "q": "git_panel::Close",
      "space b": "git_panel::ToggleFocus",
      "space g g": "git_panel::Toggle"
    }
  },
  {
    "context": "GitPanel && ChangesList",
    "bindings": {
      "c": "git::Commit",
      "s": "git::StageFile",
      "shift-s": "git::StageAll",
      "shift-u": "git::UnstageAll",
      "u": "git::UnstageFile",
      "x": "git::RestoreFile"
    }
  },
  {
    "context": "CollabPanel && not_editing",
    "bindings": {
      "q": "workspace::ToggleLeftDock",
      "space e": "workspace::ToggleLeftDock"
    }
  },
  {
    "context": "AgentPanel",
    "bindings": {
      "cmd-k": "agent::Toggle",
      "ctrl-\\": "agent::ToggleFocus",
      "ctrl-w": "agent::ToggleFocus"
    }
  },
  {
    "context": "AgentPanel && !Editor && !Terminal && !menu",
    "bindings": {
      "space a": "agent::Toggle"
    }
  },
  {
    "context": "Pane && !Editor && !Terminal && !menu",
    "bindings": {
      "space c": "pane::CloseActiveItem"
    }
  },
  {
    "context": "Dock || Editor",
    "bindings": {
      "ctrl-w o": "workspace::CloseAllDocks",
      "ctrl-w à": ["workspace::ActivatePane", 0]
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-c": null,
      "ctrl-t": "workspace::NewTerminal",
      "ctrl-w": "pane::CloseActiveItem",
      "ctrl-x": "workspace::ToggleBottomDock",
      "space t": "terminal_panel::Toggle"
    }
  }
]
